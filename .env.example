# ClinicalTrials.gov MCP Server — Environment Configuration
# Copy this to .env and adjust as needed. No API keys required.

# Server
PORT=8000

# Cache (SQLite file path — use /data/ctgov.db on Render with persistent disk)
CACHE_PATH=.cache/ctgov.db

# TTL configuration (days)
# STATUS_TTL_DAYS: how long recruiting/status data is considered fresh (patient safety critical)
STATUS_TTL_DAYS=7

# META_TTL_DAYS: how long design/eligibility structure is cached
META_TTL_DAYS=30

# CT.gov API base URL (do not change unless testing against a mirror)
CTGOV_BASE_URL=https://clinicaltrials.gov/api/v2/studies

# Rate limiting: minimum seconds between API requests (CT.gov ToU: conservative rate)
CTGOV_RATE_INTERVAL=1.0

# Request timeout in seconds
CTGOV_TIMEOUT=30.0
